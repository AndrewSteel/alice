    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst item = $input.first().json;\nlet needs_ocr = true;\ntry {\n  // Read first 64KB only — enough to find text markers\n  const fd = fs.openSync(item.file_path, 'r');\n  const buf = Buffer.alloc(65536);\n  fs.readSync(fd, buf, 0, 65536, 0);\n  fs.closeSync(fd);\n  const sample = buf.toString('latin1');\n  // BT (Begin Text) is present in every PDF with a real text layer\n  needs_ocr = !(sample.includes('BT ') || sample.includes('BT\\n') || sample.includes('BT\\r'));\n} catch(e) {\n  // On error: safe default — assume OCR needed\n  needs_ocr = true;\n}\nreturn [{ json: { ...item, needs_ocr } }];"
      },
      "type": "n8n-nodes-base.code",
