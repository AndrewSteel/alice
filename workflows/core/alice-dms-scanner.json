      "parameters": {
        "jsCode": "const fs = require('fs');\nconst item = $('Code: Hash + Size').first().json;\nlet size_stable = false;\ntry {\n  const stat = fs.statSync(item.file_path);\n  size_stable = (stat.size === item.original_size);\n} catch(e) {\n  size_stable = false;\n}\nreturn [{ json: { ...item, size_stable } }];"
