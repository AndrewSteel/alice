      "parameters": {
        "jsCode": "const fs = require('fs');\nconst hashItem = $('Code: Hash + Size').first().json;\nconst lifecycleItem = $('Code: Lifecycle Check').first().json;\n// Merge hash data with lifecycle fields (_lifecycle_action, _old_hash)\nconst item = { ...hashItem, ...lifecycleItem };\nlet size_stable = false;\ntry {\n  const stat = fs.statSync(item.file_path);\n  size_stable = (stat.size === item.original_size);\n} catch(e) {\n  size_stable = false;\n}\nreturn [{ json: { ...item, size_stable } }];"
