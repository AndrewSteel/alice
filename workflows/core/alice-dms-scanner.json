      "id": "50e6f937-1d65-46b6-8b60-42a071d48867",
      "name": "IF: Hash OK"
    },
    {
      "parameters": {
        "jsCode": "const redis = require('redis');\nconst fs = require('fs');\nconst item = $input.first().json;\nconst filePath = item.file_path;\nconst currentHash = item.file_hash;\n\nif (!currentHash) {\n  return [{ json: { ...item, _lifecycle_action: 'skip', _skip: true } }];\n}\n\nlet redisPw = ''; try { redisPw = $env.REDIS_PASSWORD || ''; } catch(e) {}\nconst client = redis.createClient({ socket: { host: 'redis', port: 6379 }, password: redisPw || undefined });\nawait client.connect();\ntry {\n  // Check 1: Known path -> hash mapping\n  const knownHashForPath = await client.hGet('alice:dms:path_to_hash', filePath);\n  \n  if (knownHashForPath) {\n    if (knownHashForPath === currentHash) {\n      return [{ json: { ...item, _lifecycle_action: 'already_processed', _skip: true } }];\n    } else {\n      // File changed: same path, different hash\n      await client.sRem('alice:dms:processed', knownHashForPath);\n      return [{ json: { ...item, _lifecycle_action: 'replace', _old_hash: knownHashForPath } }];\n    }\n  }\n  \n  // Check 2: Is this hash already processed (potentially at a different path)?\n  const isProcessed = await client.sIsMember('alice:dms:processed', currentHash);\n  \n  if (isProcessed) {\n    const knownPaths = await client.sMembers(`alice:dms:hash_to_paths:${currentHash}`);\n    \n    if (knownPaths.length === 0) {\n      return [{ json: { ...item, _lifecycle_action: 'new' } }];\n    }\n    \n    const existingPaths = knownPaths.filter(p => {\n      try { fs.accessSync(p, fs.constants.F_OK); return true; } catch(e) { return false; }\n    });\n    \n    if (existingPaths.length === 0) {\n      return [{ json: { ...item, _lifecycle_action: 'update_path', _old_paths: knownPaths } }];\n    } else {\n      const deadPaths = knownPaths.filter(p => !existingPaths.includes(p));\n      for (const p of deadPaths) {\n        await client.sRem(`alice:dms:hash_to_paths:${currentHash}`, p);\n      }\n      return [{ json: { ...item, _lifecycle_action: 'add_path', _known_paths: existingPaths } }];\n    }\n  }\n  \n  // Check 3: Is hash currently in the processing queue?\n  const isQueued = await client.sIsMember('alice:dms:queued_files', currentHash);\n  if (isQueued) {\n    return [{ json: { ...item, _lifecycle_action: 'already_queued', _skip: true } }];\n  }\n  \n  return [{ json: { ...item, _lifecycle_action: 'new' } }];\n  \n} finally {\n  await client.quit();\n}"
      },
